{
  "name": "@stellar-identity/sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for Stellar decentralized identity and verifiable credentials",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "jest",
    "lint": "eslint src/**/*.ts",
    "prepare": "npm run build",
    "example:cli-demo": "ts-node --script-mode examples/cli-demo.ts"
  },
  "keywords": [
    "stellar",
    "decentralized-identity",
    "verifiable-credentials",
    "did",
    "blockchain",
    "soroban"
  ],
  "author": "Stellar Identity Team",
  "license": "Apache-2.0",
  "dependencies": {
    "stellar-sdk": "^12.0.0",
    "did-resolver": "^4.1.0",
    "web-did-resolver": "^2.0.27",
    "did-jwt": "^7.2.3",
    "did-jwt-vc": "^3.2.5",
    "axios": "^1.6.0",
    "crypto-js": "^4.2.0",
    "tweetnacl": "^1.0.3",
    "bs58": "^5.0.0",
    "multiformats": "^12.1.0",
    "uint8arrays": "^4.0.6",
    "snarkjs": "^0.7.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/jest": "^29.5.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "jest": "^29.5.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.0.0"
  },
  "files": [
    "dist/**/*",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/stellar-identity/sdk.git"
  },
  "bugs": {
    "url": "https://github.com/stellar-identity/sdk/issues"
  },
  "homepage": "https://github.com/stellar-identity/sdk#readme"
}
